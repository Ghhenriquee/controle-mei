datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Transacao {
  id        Int      @id @default(autoincrement())
  descricao String
  valor     Float
  tipo      String
  categoria String
  data      DateTime @default(now())
  criadoEm DateTime @default(now())
}
